# MetaKizz / Ambassador app — environment variables.
# Copy to `.env` and fill in real values. Never commit `.env`.

# ─── Flask core ──────────────────────────────────────────────────
FLASK_SECRET_KEY=change-me-to-a-long-random-string
# Local dev: defaults to sqlite. Render injects DATABASE_URL automatically.
DATABASE_URL=

# Public URL of THIS Flask app (used in email links, unsubscribe URLs).
APP_URL=http://localhost:5000
# Public landing where ambassadors send their referrals (Lovable PLF page).
LANDING_URL=http://localhost:5000

# ─── Admin panel ────────────────────────────────────────────────
ADMIN_PASSWORD=change-me

# ─── Email (Resend) ─────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=MetaKizz <noreply@metakizzproject.com>

# ─── Circle.so API ──────────────────────────────────────────────
CIRCLE_API_TOKEN=
CIRCLE_COMMUNITY_ID=161276

# ─── Partner Invite flow (Couple plan) ──────────────────────────
# The flow mirrors the buyer's access group: if the buyer is in Dancers,
# the partner is added to Dancers; same for Instructors. We need both IDs.
# Get them from Circle: Settings → Access groups → click on the group →
# the URL contains the ID (e.g. .../access_groups/12345/edit).
CIRCLE_ACCESS_GROUP_DANCERS_ID=
CIRCLE_ACCESS_GROUP_INSTRUCTORS_ID=
# Where admin alerts go when a Circle invite call fails.
ADMIN_NOTIFICATION_EMAIL=alvarohertinez@gmail.com

# ─── GoHighLevel webhook ────────────────────────────────────────
GHL_WEBHOOK_SECRET=

# ─── Cron jobs ──────────────────────────────────────────────────
CRON_SECRET=

# ─── WhatsApp ───────────────────────────────────────────────────
WHATSAPP_GROUP_URL=

# ─── Campaign timing ────────────────────────────────────────────
# Hard close — used by cron + admin countdown badge.
CAMPAIGN_CLOSE_ISO=2026-05-07T19:00:00+02:00
# Weekend re-open of recordings. Anything before this ts = "first view";
# anything after = "rewatch".
REWATCH_WINDOW_OPENS_AT=2026-05-09T00:00:00+02:00
# Per-class overrides (optional; default to REWATCH_WINDOW_OPENS_AT).
REWATCH_WINDOW_OPENS_AT_CLASS1=
REWATCH_WINDOW_OPENS_AT_CLASS2=
REWATCH_WINDOW_OPENS_AT_CLASS3=
